{
  "mcpServers": {
    "neo4j-aj-kb": {
      "command": "uvx",
      "args": ["mcp-neo4j-cypher@latest", "--transport", "stdio"],
      "env": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "aj-knowledge",
        "NEO4J_DATABASE": "neo4j",
        "NEO4J_NAMESPACE": "aj-kb"
      }
    },
    "opik": {
      "command": "npx",
      "args": ["-y", "opik-mcp", "--apiBaseUrl", "http://localhost:5173/api"]
    }
  }
}
