# Anthropic API (primary provider)
ANTHROPIC_API_KEY=sk-ant-...

# LiteLLM proxy connection (fallback — handles PII filtering and observability)
# LLM provider keys are configured in litellm/.env, not here.
LITELLM_API_KEY=sk-litellm-dev-key

# Note: Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and will not be committed.
